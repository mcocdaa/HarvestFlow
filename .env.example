# ============================================
# HarvestFlow 环境配置模板
# 复制此文件为 .env 并根据需要修改
# ============================================

# --------------------------------------------
# 运行环境
# --------------------------------------------
# development: 开发环境（本地运行）
# production: 生产环境（Docker 部署）
ENVIRONMENT=development

# --------------------------------------------
# Docker 端口配置（用于 Docker 模式）
# --------------------------------------------
# 后端：内部固定 3000，外部可配置
BACKEND_EXTERNAL_PORT=3001
# 前端：内部固定 8000，外部可配置
FRONTEND_EXTERNAL_PORT=8001

# --------------------------------------------
# 后端配置
# --------------------------------------------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
API_VERSION=v1

# CORS 配置（开发环境允许所有，生产环境请指定域名）
CORS_ORIGINS=*

# --------------------------------------------
# 数据目录配置
# --------------------------------------------
DATA_DIR=./backend/data
DB_PATH=./backend/data/db/harvestflow.db
PLUGINS_DIR=./plugins

# --------------------------------------------
# 前端配置（开发环境）
# --------------------------------------------
# 前端开发服务器端口
FRONTEND_DEV_PORT=5173
# 后端 API 地址（前端代理目标）
VITE_API_BASE_URL=http://localhost:3000

# --------------------------------------------
# 仅前端模式配置
# --------------------------------------------
# 连接到已有的后端服务地址
BACKEND_URL=http://localhost:3001
