# ============================================
# HarvestFlow 环境配置
# ============================================

# --------------------------------------------
# 运行环境
# --------------------------------------------
# development: 开发环境（本地运行）
# production: 生产环境（Docker 部署）
ENVIRONMENT=development

# --------------------------------------------
# Docker 端口配置
# --------------------------------------------
BACKEND_EXTERNAL_PORT=3001
FRONTEND_EXTERNAL_PORT=8001

# --------------------------------------------
# 后端配置
# --------------------------------------------
HOST=0.0.0.0
PORT=3000
API_VERSION=v1
DATA_DIR=./backend/data
LOG_LEVEL=INFO

# CORS 配置
CORS_ORIGINS=*

# --------------------------------------------
# 数据库配置
# --------------------------------------------
DB_PATH=./backend/data/db/harvestflow.db
PLUGINS_DIR=./plugins
SECRETS_YAML=./secrets/backend.yaml

# --------------------------------------------
# Collector Manager 配置
# --------------------------------------------
# 监控文件夹列表，逗号分隔
WATCH_FOLDERS=
# 轮询间隔（秒）
POLL_INTERVAL=60

# --------------------------------------------
# Session Manager 配置
# --------------------------------------------
# 会话数据目录（不设置则使用 DATA_DIR）
SESSION_DATA_DIR=

# --------------------------------------------
# Curator Manager 配置
# --------------------------------------------
# 是否启用自动审核
CURATOR_ENABLED=true
# 自动审批阈值
AUTO_APPROVE_THRESHOLD=4

# --------------------------------------------
# Reviewer Manager 配置
# --------------------------------------------
# 审核数据目录（不设置则使用 DATA_DIR）
REVIEWER_DATA_DIR=

# --------------------------------------------
# Exporter Manager 配置
# --------------------------------------------
# 默认导出格式（sharegpt/alpaca）
EXPORT_DEFAULT_FORMAT=sharegpt
# 导出输出目录（不设置则使用 DATA_DIR/export）
EXPORT_OUTPUT_DIR=

# --------------------------------------------
# 前端配置
# --------------------------------------------
# 本地开发时使用 BACKEND_EXTERNAL_PORT (3001)
# Docker 部署时由 docker-compose.yml 覆盖为 harvestflow-backend:3000
VITE_API_BASE_URL=http://localhost:3001
